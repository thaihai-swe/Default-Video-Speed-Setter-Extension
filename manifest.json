{
    "manifest_version": 3,
    "name": "Default Video Speed Setter",
    "version": "1.1",
    "description": "Automatically snaps all web videos to your preferred speed.",
    "permissions": [
        "storage"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "action": {
        "default_popup": "options.html",
        "default_title": "AutoPlay Speed Setter",
        "default_icon": {
            "16": "icon.png",
            "48": "icon.png",
            "128": "icon.png"
        }
    },
    "icons": {
        "128": "icon.png"
    }
}
